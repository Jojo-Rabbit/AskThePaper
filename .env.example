# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Optional: AWS S3 archival (leave blank to skip) ───────────────────────────
AWS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Tuning (safe to leave as defaults) ───────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=6
MODEL=claude-sonnet-4-5
MAX_TOKENS=1500
UPLOAD_FOLDER=./uploads
CHROMA_PATH=./chroma_db
